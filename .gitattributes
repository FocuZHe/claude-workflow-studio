# Auto detect text files and perform LF normalization
* text=auto

# Force batch scripts to use CRLF (required for Windows cmd.exe)
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts use LF
*.sh text eol=lf

# Keep binary files unchanged
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
